pipeline {
    agent any

    parameters {
        string(name: 'ONLY_IMAGE', defaultValue: '', description: 'Sadece belirli bir imaji derle (orn: livestocktrading-api). Bos birakilirsa tum imajlar derlenir.')
        booleanParam(name: 'NO_CACHE', defaultValue: false, description: 'Docker build cache kullanma')
        booleanParam(name: 'DEPLOY_TO_DEV', defaultValue: true, description: 'Build sonrasi DEV ortamina otomatik deploy yap')
        booleanParam(name: 'RUN_MIGRATIONS', defaultValue: true, description: 'Deploy sonrasi migration ve seeder calistir')
    }

    environment {
        REGISTRY = 'docker.io'
        TAG_SUFFIX = 'dev-latest'
        IMMUTABLE_TAG = "dev-${BUILD_ID}-${GIT_COMMIT.take(8)}"
        DOCKER_BUILDKIT = '1'
        COMPOSE_HTTP_TIMEOUT = '1200'
        DOCKER_CLIENT_TIMEOUT = '1200'

        DOCKERHUB_CREDENTIAL_ID = 'dockerhub-credentials'
        SERVER_SSH_KEY_ID = 'maden-server-key'
        SERVER_HOST_ID = 'dev-server-host'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 3, unit: 'HOURS')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "DEV: Kod cekiliyor..."
                    sh '''
                        git submodule update --init --recursive || true
                        echo "Kod basariyla cekildi"
                        echo "Branch: ${GIT_BRANCH}"
                        echo "Commit: ${GIT_COMMIT}"
                    '''
                }
            }
        }

        stage('Generate Build Matrix') {
            steps {
                script {
                    def allModules = [
                        'livestocktrading-api:_devops/docker/Dockerfile.livestocktrading-api:mstfaock/livestocktrading-api',
                        'iam-api:_devops/docker/Dockerfile.iam-api:mstfaock/livestocktrading-iam-api',
                        'fileprovider-api:_devops/docker/Dockerfile.fileprovider-api:mstfaock/livestocktrading-fileprovider-api',
                        'iam-mail-worker:_devops/docker/Dockerfile.iam-mail-worker:mstfaock/livestocktrading-iam-mail-worker',
                        'iam-sms-worker:_devops/docker/Dockerfile.iam-sms-worker:mstfaock/livestocktrading-iam-sms-worker',
                        'resource-seeder:_devops/docker/Dockerfile.resource-seeder:mstfaock/livestocktrading-resource-seeder'
                    ]

                    def modulesToBuild = []
                    if (params.ONLY_IMAGE) {
                        def found = allModules.find { it.split(':')[0] == params.ONLY_IMAGE }
                        if (!found) {
                            error "'${params.ONLY_IMAGE}' isimli modul bulunamadi!"
                        }
                        modulesToBuild.add(found)
                        echo "DEV: Sadece '${params.ONLY_IMAGE}' modulu derlenecek"
                    } else {
                        modulesToBuild = allModules
                        echo "DEV: Tum moduller derlenecek (${modulesToBuild.size()} adet)"
                    }

                    env.BUILD_MODULES = modulesToBuild.join('|')
                }
            }
        }

        stage('Docker Login') {
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: env.DOCKERHUB_CREDENTIAL_ID,
                        usernameVariable: 'DOCKER_USERNAME',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )]) {
                        sh '''
                            echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin > /dev/null 2>&1 && \
                            echo "Docker Hub login basarili (DEV)" || \
                            (echo "Docker login basarisiz!"; exit 1)
                        '''
                    }
                }
            }
        }

        stage('Build & Push Images') {
            steps {
                script {
                    def modules = env.BUILD_MODULES.split('\\|')

                    modules.eachWithIndex { moduleStr, index ->
                        def parts = moduleStr.split(':')
                        def moduleName = parts[0]
                        def dockerfile = parts[1]
                        def image = parts[2]

                        echo "DEV [${index + 1}/${modules.size()}] ${moduleName} build ediliyor..."

                        def cacheArgs = params.NO_CACHE ? '--no-cache' : ''

                        timeout(time: 45, unit: 'MINUTES') {
                            sh """
                                docker buildx build \
                                    ${cacheArgs} \
                                    --progress=auto \
                                    --file ${dockerfile} \
                                    --tag ${image}:${TAG_SUFFIX} \
                                    --tag ${image}:${IMMUTABLE_TAG} \
                                    --label org.opencontainers.image.revision=${GIT_COMMIT} \
                                    --label org.opencontainers.image.version=${IMMUTABLE_TAG} \
                                    --provenance=false \
                                    --sbom=false \
                                    --pull \
                                    --push .
                            """
                        }

                        echo "${moduleName} basariyla build edildi ve push edildi (${index + 1}/${modules.size()})"
                        sh 'docker builder prune -f --filter type=exec.cachemount || true'
                    }

                    echo "Tum imajlar basariyla build edildi ve Docker Hub'a push edildi!"
                }
            }
        }

        stage('Deploy to DEV') {
            when {
                allOf {
                    expression {
                        env.GIT_BRANCH == 'dev' ||
                        env.GIT_BRANCH == 'origin/dev' ||
                        env.GIT_BRANCH.endsWith('/dev')
                    }
                    expression { params.DEPLOY_TO_DEV == true }
                }
            }
            steps {
                script {
                    echo "DEV ortamina deploy basliyor..."

                    withCredentials([
                        sshUserPrivateKey(credentialsId: env.SERVER_SSH_KEY_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                        string(credentialsId: env.SERVER_HOST_ID, variable: 'SERVER_HOST'),
                        usernamePassword(credentialsId: env.DOCKERHUB_CREDENTIAL_ID, usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')
                    ]) {
                        def sshUser = SSH_USER
                        def sshHost = SERVER_HOST
                        def dockerUser = DOCKER_USERNAME
                        def dockerPass = DOCKER_PASSWORD

                        sh """
                            chmod 600 "\$SSH_KEY"

                            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${sshUser}@${sshHost} bash <<'ENDSSH'
export DOCKER_USERNAME='${dockerUser}'
export DOCKER_PASSWORD='${dockerPass}'

set -e

BASE_DIR="/opt/livestocktrading"
REPO_DIR="\$BASE_DIR/repo"

if [ ! -d "\$REPO_DIR/.git" ]; then
    echo "Git repo bulunamadi: \$REPO_DIR"
    exit 1
fi

echo "Git repo bulundu: \$REPO_DIR"

echo "Git repository guncelleniyor (dev branch)..."
cd "\$REPO_DIR"
git fetch origin dev
git reset --hard origin/dev
git submodule update --init --recursive

echo "Docker Hub login yapiliyor..."
echo "\$DOCKER_PASSWORD" | docker login -u "\$DOCKER_USERNAME" --password-stdin || {
    echo "Docker Hub login basarisiz!";
    exit 1;
}

echo "Docker compose dizinine geciliyor..."
cd "\$REPO_DIR/_devops/docker/compose"

echo "Mevcut servisleri durduruluyor..."
docker compose -p livestock_dev \\
    -f docker-compose.yml \\
    -f docker-compose.dev.yml \\
    --env-file \$BASE_DIR/.env.dev \\
    down --remove-orphans || true

echo "Docker imajlari cekiliyor..."
docker compose -p livestock_dev \\
    -f docker-compose.yml \\
    -f docker-compose.dev.yml \\
    --env-file \$BASE_DIR/.env.dev \\
    pull

echo "Servisler yeniden baslatiliyor..."
docker compose -p livestock_dev \\
    -f docker-compose.yml \\
    -f docker-compose.dev.yml \\
    --env-file \$BASE_DIR/.env.dev \\
    up -d --remove-orphans

echo "Servislerin hazir olmasi bekleniyor (30 saniye)..."
sleep 30

echo "Eski Docker imajlari temizleniyor..."
docker image prune -f

echo "DEV deploy basariyla tamamlandi!"
ENDSSH
                        """
                    }
                }
            }
        }

        stage('Run Migrations & Seeders') {
            when {
                allOf {
                    expression { return params.DEPLOY_TO_DEV }
                    expression { return params.RUN_MIGRATIONS }
                }
            }
            steps {
                script {
                    echo "Database migration ve seeding basliyor..."

                    withCredentials([
                        sshUserPrivateKey(credentialsId: env.SERVER_SSH_KEY_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                        string(credentialsId: env.SERVER_HOST_ID, variable: 'SERVER_HOST')
                    ]) {
                        def sshUser = SSH_USER
                        def sshHost = SERVER_HOST

                        sh """
                            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${sshUser}@${sshHost} bash <<'ENDSSH'
set -e

BASE_DIR="/opt/livestocktrading"
REPO_DIR="\$BASE_DIR/repo"

if [ ! -d "\$REPO_DIR" ]; then
    echo "Proje dizini bulunamadi: \$REPO_DIR"
    exit 1
fi

echo "Proje dizini bulundu: \$REPO_DIR"
cd "\$REPO_DIR/_devops/docker/compose"

echo "ResourceSeeder calistiriliyor (development)..."
docker run --rm \\
    --network livestock_dev_livestocktrading-network \\
    --env-file \$BASE_DIR/.env.dev \\
    mstfaock/livestocktrading-resource-seeder:dev-latest \\
    development || {
    echo "ResourceSeeder basarisiz oldu, devam ediliyor..."
}

echo "Migration ve Seeding tamamlandi!"
ENDSSH
                        """
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                script {
                    echo "Jenkins build artifacts temizleniyor..."
                    sh '''
                        docker image prune -f || true
                        docker builder prune -f --filter type=exec.cachemount || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "DEV Pipeline basariyla tamamlandi!"
            echo "Build ID: ${BUILD_ID}"
            echo "Commit: ${GIT_COMMIT}"
            echo "Tag: ${IMMUTABLE_TAG}"
            echo "Ortam: DEV"
        }
        failure {
            echo "DEV Pipeline basarisiz oldu!"
            echo "Build ID: ${BUILD_ID}"
            echo "Commit: ${GIT_COMMIT}"
        }
        always {
            sh 'docker logout || true'
        }
    }
}
