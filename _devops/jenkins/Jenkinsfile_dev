pipeline {
    agent any

    parameters {
        string(name: 'ONLY_IMAGE', defaultValue: '', description: 'Sadece belirli bir imajı derle (örn: hirovo-api, animalmarket-api). Boş bırakılırsa tüm imajlar derlenir.')
        booleanParam(name: 'NO_CACHE', defaultValue: false, description: 'Docker build cache kullanma')
        booleanParam(name: 'PLAIN_LOGS', defaultValue: false, description: 'Detaylı build logları göster')
        booleanParam(name: 'DEPLOY_TO_DEV', defaultValue: true, description: 'Build sonrası DEV ortamına otomatik deploy yap')
        booleanParam(name: 'RUN_MIGRATIONS', defaultValue: true, description: 'Deploy sonrası migration ve seeder çalıştır')
    }

    environment {
        REGISTRY = 'docker.io'
        TAG_SUFFIX = 'dev-latest'
        IMMUTABLE_TAG = "dev-${BUILD_ID}-${GIT_COMMIT.take(8)}"
        DOCKER_BUILDKIT = '1'
        COMPOSE_HTTP_TIMEOUT = '1200'
        DOCKER_CLIENT_TIMEOUT = '1200'

        DOCKERHUB_CREDENTIAL_ID = 'dockerhub-credentials'
        SERVER_SSH_KEY_ID = 'maden-server-key'
        SERVER_HOST_ID = 'dev-server-host'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 3, unit: 'HOURS')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "🔄 DEV: Kod çekiliyor..."
                    sh '''
                        git submodule update --init --recursive || true
                        echo " Kod başarıyla çekildi"
                        echo "📌 Branch: ${GIT_BRANCH}"
                        echo "📌 Commit: ${GIT_COMMIT}"
                    '''
                }
            }
        }

        stage('Generate Build Matrix') {
            steps {
                script {
                    def allModules = [
                        'hirovo-api:./_devops/docker/Dockerfile-modules-hirovo:mstfaock/hirovo-api',
                        'iam-api:./_devops/docker/Dockerfile-modules-iam:mstfaock/maden-iam-api',
                        'api-gateway:./_devops/docker/Dockerfile-api-gateway:mstfaock/maden-api-gateway',
                        'fileprovider-api:./_devops/docker/Dockerfile-modules-fileprovider:mstfaock/maden-fileprovider-api',
                        'sms-worker:./_devops/docker/Dockerfile-modules-sms:mstfaock/hirovo-sms-worker',
                        'email-worker:./_devops/docker/Dockerfile-modules-mail:mstfaock/hirovo-email-worker',
                        'notification-worker:./_devops/docker/Dockerfile-modules-notification:mstfaock/hirovo-notification-worker',
                        'iam-email-worker:./_devops/docker/Dockerfile-modules-iam-mail:mstfaock/iam-email-worker',
                        'iam-sms-worker:./_devops/docker/Dockerfile-modules-iam-sms:mstfaock/iam-sms-worker',
                        'animalmarket-notification-worker:./_devops/docker/Dockerfile-modules-animalmarket-notification:mstfaock/animalmarket-notification-worker',
                        'animalmarket-email-worker:./_devops/docker/Dockerfile-modules-animalmarket-mail:mstfaock/animalmarket-email-worker',
                        'animalmarket-sms-worker:./_devops/docker/Dockerfile-modules-animalmarket-sms:mstfaock/animalmarket-sms-worker',
                        'animalmarket-api:./_devops/docker/Dockerfile-modules-animalmarket:mstfaock/animalmarket-api',
                        'keepzo-api:./_devops/docker/Dockerfile-modules-keepzo:mstfaock/keepzo-api',
                        'hangfire-scheduler:./_devops/docker/Dockerfile-hangfire-scheduler:mstfaock/hangfire-scheduler'
                    ]

                    def modulesToBuild = []
                    if (params.ONLY_IMAGE) {
                        def found = allModules.find { it.split(':')[0] == params.ONLY_IMAGE }
                        if (!found) {
                            error "❌ '${params.ONLY_IMAGE}' isimli modül bulunamadı!"
                        }
                        modulesToBuild.add(found)
                        echo " DEV: Sadece '${params.ONLY_IMAGE}' modülü derlenecek"
                    } else {
                        modulesToBuild = allModules
                        echo " DEV: Tüm modüller derlenecek (${modulesToBuild.size()} adet)"
                    }

                    env.BUILD_MODULES = modulesToBuild.join('|')
                }
            }
        }

        stage('Docker Login') {
            steps {
                script {
                    withCredentials([usernamePassword(
                        credentialsId: env.DOCKERHUB_CREDENTIAL_ID,
                        usernameVariable: 'DOCKER_USERNAME',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )]) {
                        sh '''
                            echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin > /dev/null 2>&1 && \
                            echo " Docker Hub login başarılı (DEV)" || \
                            (echo "❌ Docker login başarısız!"; exit 1)
                        '''
                    }
                }
            }
        }

        stage('Build & Push Images') {
            steps {
                script {
                    def modules = env.BUILD_MODULES.split('\\|')

                    modules.eachWithIndex { moduleStr, index ->
                        def parts = moduleStr.split(':')
                        def moduleName = parts[0]
                        def dockerfile = parts[1]
                        def image = parts[2]

                        echo "🔨 DEV [${index + 1}/${modules.size()}] ${moduleName} build ediliyor..."

                        def cacheArgs = params.NO_CACHE ? '--no-cache' : ''
                        def progressArg = params.PLAIN_LOGS ? '--progress=plain' : '--progress=auto'

                        timeout(time: 45, unit: 'MINUTES') {
                            sh """
                                docker buildx build \
                                    ${cacheArgs} \
                                    ${progressArg} \
                                    --file ${dockerfile} \
                                    --tag ${image}:${TAG_SUFFIX} \
                                    --tag ${image}:${IMMUTABLE_TAG} \
                                    --build-arg ASPNETCORE_URLS=http://+:8080 \
                                    --label org.opencontainers.image.revision=${GIT_COMMIT} \
                                    --label org.opencontainers.image.version=${IMMUTABLE_TAG} \
                                    --label org.opencontainers.image.created=\$(date -u +'%Y-%m-%dT%H:%M:%SZ') \
                                    --provenance=false \
                                    --sbom=false \
                                    --pull \
                                    --push .
                            """
                        }

                        echo " ${moduleName} başarıyla build edildi ve push edildi (${index + 1}/${modules.size()})"
                        sh 'docker builder prune -f --filter type=exec.cachemount || true'
                    }

                    echo "🎉 Tüm imajlar başarıyla build edildi ve Docker Hub'a push edildi!"
                }
            }
        }

        stage('Deploy to DEV') {
            when {
                allOf {
                    expression { 
                        env.GIT_BRANCH == 'dev' || 
                        env.GIT_BRANCH == 'origin/dev' || 
                        env.GIT_BRANCH.endsWith('/dev') 
                    }
                    expression { params.DEPLOY_TO_DEV == true }
                }
            }
            steps {
                script {
                    echo "🚀 DEV ortamına deploy başlıyor..."
                    
                    withCredentials([
                        sshUserPrivateKey(credentialsId: env.SERVER_SSH_KEY_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                        string(credentialsId: env.SERVER_HOST_ID, variable: 'SERVER_HOST'),
                        usernamePassword(credentialsId: env.DOCKERHUB_CREDENTIAL_ID, usernameVariable: 'DOCKER_USERNAME', passwordVariable: 'DOCKER_PASSWORD')
                    ]) {
                        def sshUser = SSH_USER
                        def sshHost = SERVER_HOST
                        def dockerUser = DOCKER_USERNAME
                        def dockerPass = DOCKER_PASSWORD
                        
                        sh """
                            chmod 600 "\$SSH_KEY"
                            
                            ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${sshUser}@${sshHost} bash <<'ENDSSH'
export DOCKER_USERNAME='${dockerUser}'
export DOCKER_PASSWORD='${dockerPass}'

set -e

echo "🔍 Proje dizinini buluyorum..."
PROJECT_DIR=""
for d in /maden/backend /root/maden-backend /opt/maden/backend \$(pwd)/maden-backend; do
    if [ -d "\$d" ]; then
        PROJECT_DIR="\$d"
        break
    fi
done

if [ -z "\$PROJECT_DIR" ] || [ ! -d "\$PROJECT_DIR" ]; then
    echo "❌ Proje dizini bulunamadı!"
    exit 1
fi

echo " Proje dizini bulundu: \$PROJECT_DIR"

echo "🔄 Git repository güncelleniyor (dev branch)..."
cd "\$PROJECT_DIR"
git fetch origin dev
git reset --hard origin/dev
git submodule update --init --recursive

echo "📂 Docker dizinine geçiliyor..."
cd "\$PROJECT_DIR/_devops/docker"

echo "🔐 Docker Hub login yapılıyor..."
echo "\$DOCKER_PASSWORD" | docker login -u "\$DOCKER_USERNAME" --password-stdin || { 
    echo "❌ Docker Hub login başarısız!";
    exit 1;
}

if [ ! -f "env/dev.env" ]; then
    echo "❌ env/dev.env dosyası bulunamadı!"
    ls -la env/ || true
    exit 1
fi

echo " Environment dosyası bulundu: env/dev.env"

echo "📦 Docker imajları çekiliyor..."
docker compose -p maden_dev \\
    --env-file env/dev.env \\
    -f compose/common.yml \\
    -f compose/dev.yml \\
    pull

echo "🚀 Servisler yeniden başlatılıyor..."
docker compose -p maden_dev \\
    --env-file env/dev.env \\
    -f compose/common.yml \\
    -f compose/dev.yml \\
    up -d

echo "⏳ Servislerin hazır olması bekleniyor (30 saniye)..."
sleep 30

echo "🧹 Eski Docker imajları temizleniyor..."
docker image prune -f

echo " DEV deploy başarıyla tamamlandı!"
ENDSSH
                        """
                    }
                }
            }
        }

stage('Run Migrations & Seeders') {
    when {
        allOf {
            expression { return params.DEPLOY_TO_DEV }
            expression { return params.RUN_MIGRATIONS }
        }
    }
    steps {
        script {
            echo "🗄️ Database migration ve seeding başlıyor..."
            
            withCredentials([
                sshUserPrivateKey(credentialsId: env.SERVER_SSH_KEY_ID, keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER'),
                string(credentialsId: env.SERVER_HOST_ID, variable: 'SERVER_HOST')
            ]) {
                def sshUser = SSH_USER
                def sshHost = SERVER_HOST
                
                sh """
                    ssh -o StrictHostKeyChecking=no -i "\$SSH_KEY" ${sshUser}@${sshHost} bash <<'ENDSSH'
set -e

echo "🔍 Proje dizinini buluyorum..."
PROJECT_DIR=""
for d in /maden/backend /root/maden-backend /opt/maden/backend \$(pwd)/maden-backend; do
    if [ -d "\$d" ]; then
        PROJECT_DIR="\$d"
        break
    fi
done

if [ -z "\$PROJECT_DIR" ] || [ ! -d "\$PROJECT_DIR" ]; then
    echo "❌ Proje dizini bulunamadı"
    exit 1
fi

echo " Proje dizini bulundu: \$PROJECT_DIR"
cd "\$PROJECT_DIR/_devops/docker"

echo "🗄️ Migration çalıştırılıyor (development)..."
docker run --rm \\
    --network maden-network-dev \\
    --env-file env/dev.env \\
    -v "\$PROJECT_DIR:/src" \\
    -w /src/Jobs/RelationalDB/MigrationJob \\
    mcr.microsoft.com/dotnet/sdk:8.0 \\
    dotnet run development || {
    echo "⚠️ Migration başarısız oldu, devam ediliyor..."
}

echo "🌱 Seeder çalıştırılıyor (development)..."
docker run --rm \\
    --network maden-network-dev \\
    --env-file env/dev.env \\
    -v "\$PROJECT_DIR:/src" \\
    -w /src/Jobs/SpecialPurpose/ResourceSeeder \\
    mcr.microsoft.com/dotnet/sdk:8.0 \\
    dotnet run development || {
    echo "⚠️ Seeder başarısız oldu, devam ediliyor..."
}

echo " Migration ve Seeding tamamlandı!"
ENDSSH
                """
            }
        }
    }
}

        stage('Cleanup') {
            steps {
                script {
                    echo "🧹 Jenkins build artifacts temizleniyor..."
                    sh '''
                        docker image prune -f || true
                        docker builder prune -f --filter type=exec.cachemount || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo " DEV Pipeline başarıyla tamamlandı!"
            echo "📦 Build ID: ${BUILD_ID}"
            echo "📌 Commit: ${GIT_COMMIT}"
            echo "🏷️ Tag: ${IMMUTABLE_TAG}"
            echo "🌐 Ortam: DEV"
        }
        failure {
            echo "❌ DEV Pipeline başarısız oldu!"
            echo "📦 Build ID: ${BUILD_ID}"
            echo "📌 Commit: ${GIT_COMMIT}"
        }
        always {
            sh 'docker logout || true'
        }
    }
}