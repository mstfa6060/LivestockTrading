FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Proje dosyalarini kopyala
COPY ["Gateways/Api/Gateways.ApiGateway.Api/Gateways.ApiGateway.Api.csproj", "Gateways/Api/Gateways.ApiGateway.Api/"]

# Restore
RUN dotnet restore "Gateways/Api/Gateways.ApiGateway.Api/Gateways.ApiGateway.Api.csproj"

# Tum gateway kodunu kopyala
COPY ["Gateways/", "Gateways/"]

# Build
RUN dotnet publish "Gateways/Api/Gateways.ApiGateway.Api/Gateways.ApiGateway.Api.csproj" \
    -c Release \
    -o /app/publish \
    --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
EXPOSE 8080

# ocelot.json dahil tum dosyalari kopyala
COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "Gateways.ApiGateway.Api.dll"]
