# ============================================================
# 🧱 Build Stage
# ============================================================
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Yalnızca gerekli klasörleri kopyala
COPY ["Hirovo.sln", "./"]
COPY ["BaseModules/", "BaseModules/"]
COPY ["BusinessModules/", "BusinessModules/"]
COPY ["Common/", "Common/"]
COPY ["Gateways/", "Gateways/"]
COPY ["Jobs/", "Jobs/"]

RUN dotnet restore "Hirovo.sln"

RUN dotnet publish \
    "BusinessModules/Hirovo/BusinessModules.Hirovo.Workers/MailSender/BusinessModules.Hirovo.Workers.MailSender.csproj" \
    -c Release -o /app/publish --no-restore \
    /p:DebugType=None /p:DebugSymbols=false

# ============================================================
# 🚀 Runtime Stage
# ============================================================
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

RUN groupadd -r appuser && useradd -r -g appuser appuser
COPY --from=build /app/publish .
USER appuser

EXPOSE 8080
ENTRYPOINT ["dotnet", "BusinessModules.Hirovo.Workers.MailSender.dll"]
