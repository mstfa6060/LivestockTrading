# ============================================================
# 🧱 Base build stage - Kod derleme ve publish
# ============================================================
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Çözüm (Solution) dosyası ve gerekli klasörlerin kopyalanması
COPY ["Hirovo.sln", "./"]
COPY ["BaseModules/", "BaseModules/"]
COPY ["BusinessModules/", "BusinessModules/"]
COPY ["Common/", "Common/"]
COPY ["Gateways/", "Gateways/"]
COPY ["Jobs/", "Jobs/"]

# Restore işlemi — bağımlılıkların indirilmesi
RUN dotnet restore "Hirovo.sln"

# Build & Publish
RUN dotnet publish \
    "BusinessModules/Hirovo/BusinessModules.Hirovo.Workers/NotificationSender/BusinessModules.Hirovo.Workers.NotificationSender.csproj" \
    -c Release -o /app/publish --no-restore \
    /p:DebugType=None /p:DebugSymbols=false


# ============================================================
# 🧩 Runtime stage - Sadece çalıştırma ortamı
# ============================================================
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

# Güvenli kullanıcı oluşturulması
RUN groupadd -r appuser && useradd -r -g appuser appuser

# Yayına alınan dosyaların kopyalanması
COPY --from=build /app/publish .

# Uygulama kullanıcı izinleri
USER appuser

# Çalışma portu
EXPOSE 8080

# Entry point
ENTRYPOINT ["dotnet", "BusinessModules.Hirovo.Workers.NotificationSender.dll"]
