# =====================================================
# LivestockTrading - Environment Variables
# =====================================================
# Usage: Copy to .env.dev or .env.prod and customize
# Path: docker/compose/.env

# Environment
ASPNETCORE_ENVIRONMENT=Development

# =====================================================
# SQL SERVER
# =====================================================
SA_PASSWORD=YourStrong@Passw0rd
SQL_PORT=1433
SQL_CONNECTION_STRING=Server=sqlserver,1433;Database=livestocktrading;User Id=sa;Password=YourStrong@Passw0rd;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# =====================================================
# RABBITMQ
# =====================================================
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# =====================================================
# REDIS
# =====================================================
REDIS_PORT=6379

# =====================================================
# MINIO
# =====================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=livestocktrading

# =====================================================
# MONGODB (FileProvider Document DB)
# =====================================================
MONGODB_USER=mongouser
MONGODB_PASS=mongopass
MONGODB_PORT=27017
MONGODB_DATABASE=globallivestock_fileprovider

# =====================================================
# DOCKER REGISTRY
# =====================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=mstfa6060
TAG=latest

# =====================================================
# API PORTS
# =====================================================
GATEWAY_PORT=5000
GLOBALLIVESTOCK_API_PORT=5001
IAM_API_PORT=5002
FILEPROVIDER_API_PORT=5003
# Dev: 5010, Prod: 5011 (must differ if both run on same host)
HANGFIRE_PORT=5010

# =====================================================
# EMAIL (BREVO)
# =====================================================
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_FROM_EMAIL=noreply@livestocktrading.com
BREVO_FROM_NAME=LivestockTrading

# =====================================================
# SMS (NETGSM)
# =====================================================
NETGSM_USERNAME=
NETGSM_PASSWORD=

# =====================================================
# FIREBASE (Push Notifications)
# =====================================================
# Firebase Service Account JSON content for push notifications
# Copy your entire firebase-service-account.json content as a single line
# Example: {"type":"service_account","project_id":"...","private_key":"..."}
FIREBASE__SERVICEACCOUNTJSON=
