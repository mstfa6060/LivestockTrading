FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["LivestockTrading.sln", "./"]
COPY ["BusinessModules/", "BusinessModules/"]
COPY ["BaseModules/", "BaseModules/"]
COPY ["Common/", "Common/"]
COPY ["Gateways/", "Gateways/"]
COPY ["Jobs/", "Jobs/"]

RUN dotnet restore "LivestockTrading.sln"
RUN dotnet publish "Jobs/RelationalDB/MigrationJob/Jobs.RelationalDB.MigrationJob.csproj" \
    -c Release -o /app/publish --no-restore \
    /p:DebugType=None /p:DebugSymbols=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=build /app/publish .
# appsettings and SeedData must be present at runtime
COPY --from=build /src/Jobs/RelationalDB/MigrationJob/appsettings.json ./
COPY --from=build /src/Jobs/RelationalDB/MigrationJob/appsettings.staging.json ./
COPY --from=build /src/Jobs/RelationalDB/MigrationJob/SeedData ./SeedData
ENTRYPOINT ["dotnet", "Jobs.RelationalDB.MigrationJob.dll"]
