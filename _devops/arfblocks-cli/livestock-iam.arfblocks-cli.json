    "description": "IAM modülü için endpoint dokümantasyonu",
    "company": "globallivestock",
    "commands": [
        {
            "name": "generate-docs",
            "parameters": [
                {
                    "key": "targetProject",
                    "value": "BaseModules/IAM/BaseModules.IAM.Application/BaseModules.IAM.Application.csproj"
                },
                {
                    "key": "output",
                    "value": "../web/common/livestock-api/src/api/base_modules/iam"
                },
                {
                    "key": "outputImports",
                    "value": "// Imports \nimport { AppConfig, api as axios } from '@/config/livestock-config'; \nimport { ApiService } from '@/services/ApiService';"
                },
                {
                    "key": "outputTypes",
                    "value": "// Custom Types \ntype Guid = string; \ntype Double = number; \ntype Decimal = number; \ntype DecimalNullable = number | null; \ntype Int64 = number; \ntype Int32 = number; \ntype int = number; \ntype long = number;"
                },
                {
                    "key": "outputSettings",
                    "value": "// Settings..."
                },
                {
                    "key": "nameSpace",
                    "value": "IAMAPI"
                },
                {
                    "key": "requestUrl",
                    "value": "AppConfig.IAMUrl"
                }
            ]
        },
