{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft": "Warning",
			"Microsoft.Hosting.Lifetime": "Information"
		}
	},
	"AllowedHosts": "*",
	"ProjectConfigurations": {
		"RelationalDbConfiguration": {
			"ConnectionString": "Server=YOUR_SERVER_IP,1433;Database=GlobalLivestock;User Id=globallivestock_user;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
		},
		"DocumentDbOptions": {
			"ConnectionString": "YOUR_MONGODB_CONNECTION_STRING",
			"DatabaseName": "globallivestock_fileprovider"
		},
		"EnvironmentConfiguration": {
			"EnvironmentName": "Development",
			"ApiUrl": "https://api.livestock-trading.com/fileprovider"
		}
	},
	"Caching": {
		"Redis": {
			"ConnectionString": "localhost:6379",
			"InstanceName": "globallivestock:",
			"DefaultExpirationMinutes": 60
		},
		"Memory": {
			"SizeLimitMB": 1024,
			"CompactionPercentage": 0.25
		}
	}
}