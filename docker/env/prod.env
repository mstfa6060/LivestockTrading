    # =====================================================
# GlobalLivestock - Production Environment
# =====================================================
# ⚠️ UYARI: Production şifrelerini değiştirin!

# Environment
ASPNETCORE_ENVIRONMENT=Production

# =====================================================
# SQL SERVER - GlobalLivestock Production Database
# =====================================================
# NOT: Maden ile aynı SQL Server instance, farklı DB
SA_PASSWORD=YourMadenSaPassword123!  # Maden'in SA şifresi ile aynı
SQL_PORT=1433

# GlobalLivestock Production Connection
GLOBALLIVESTOCK_DB_NAME=globallivestock_production
GLOBALLIVESTOCK_DB_USER=globallivestock_prod_user
GLOBALLIVESTOCK_DB_PASSWORD=GlobalProd@2025!VeryStrong#Secure

# Connection String - GlobalLivestock için
GLOBALLIVESTOCK_CONNECTION_STRING=Server=sqlserver,1433;Database=globallivestock_production;User Id=globallivestock_prod_user;Password=GlobalProd@2025!VeryStrong#Secure;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# Legacy format (bazı servisler için)
SQL_CONNECTION_STRING=Server=sqlserver,1433;Database=globallivestock_production;User Id=globallivestock_prod_user;Password=GlobalProd@2025!VeryStrong#Secure;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# =====================================================
# RABBITMQ
# =====================================================
RABBITMQ_USER=madenrabbit
RABBITMQ_PASS=MadenRabbitSecure123!
RMQ_AMQP_PORT=5672
RMQ_MGMT_PORT=15672

# =====================================================
# REDIS
# =====================================================
REDIS_PORT=6379

# =====================================================
# DOCKER REGISTRY
# =====================================================
REG=mstfaock
TAG=latest

# =====================================================
# API PORTS - GlobalLivestock
# =====================================================
GLOBALLIVESTOCK_API_PORT=5200
IAM_API_PORT=5201

# =====================================================
# MINIO (Object Storage)
# =====================================================
MINIO_ROOT_USER=globallivestock_minio_prod
MINIO_ROOT_PASSWORD=GlobalMinIO@2025!Production#VerySecure
MINIO_API_PORT=9020
MINIO_CONSOLE_PORT=9021
MINIO_BUCKET_NAME=globallivestock-production

# =====================================================
# FILE STORAGE
# =====================================================
GLOBALLIVESTOCK_FILE_STORAGE_PATH=/app/storage/globallivestock-prod

# =====================================================
# EMAIL SETTINGS (Brevo)
# =====================================================
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=YOUR_BREVO_USERNAME
BREVO_SMTP_PASS=YOUR_BREVO_PASSWORD
BREVO_FROM_EMAIL=noreply@livestock-trading.com
BREVO_FROM_NAME=Livestock Trading

# =====================================================
# SMS SETTINGS (Netgsm veya Türkiye SMS servisi)
# =====================================================
NETGSM_USERNAME=YOUR_NETGSM_USERNAME
NETGSM_PASSWORD=YOUR_NETGSM_PASSWORD