# GlobalLivestock Environment Configuration
# Copy this file to .env and fill in your values

# Docker Registry
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-username
TAG=latest

# Environment
ASPNETCORE_ENVIRONMENT=Development

# SQL Server
SA_PASSWORD=YourStrong@Passw0rd
SQL_PORT=1433
SQL_CONNECTION_STRING=Server=sqlserver;Database=GlobalLivestock;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Redis
REDIS_PORT=6379

# API Ports
GLOBALLIVESTOCK_API_PORT=5001
IAM_API_PORT=5002
FILEPROVIDER_API_PORT=5003
