# =====================================================
# GlobalLivestock - Development Environment
# =====================================================
# Sunucu: 45.143.4.64
# Maden'den tamamen bağımsız (sadece SQL paylaşımlı)

# Environment
ASPNETCORE_ENVIRONMENT=Development

# =====================================================
# SQL SERVER - Maden ile PAYLAŞIMLI
# =====================================================
# Maden'in Development SQL Server'ı kullanılacak
# Server: 45.143.4.64:1433
# SA Password: DevStrongPass123!

SA_PASSWORD=DevStrongPass123!
SQL_PORT=1433

# GlobalLivestock Development Database
GLOBALLIVESTOCK_DB_NAME=globallivestock_dev
GLOBALLIVESTOCK_DB_USER=globallivestock_dev_user
GLOBALLIVESTOCK_DB_PASSWORD=GlobalDev@2025!Strong

# Connection String - GlobalLivestock için
# NOT: Docker içinden "sqlserver" container adıyla bağlanılacak
GLOBALLIVESTOCK_CONNECTION_STRING=Server=sqlserver,1433;Database=globallivestock_dev;User Id=globallivestock_dev_user;Password=GlobalDev@2025!Strong;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# Legacy format (bazı servisler için)
SQL_CONNECTION_STRING=Server=sqlserver,1433;Database=globallivestock_dev;User Id=globallivestock_dev_user;Password=GlobalDev@2025!Strong;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# =====================================================
# RABBITMQ - GlobalLivestock'a ÖZEL
# =====================================================
# Maden'den bağımsız, kendi RabbitMQ'su
RABBITMQ_USER=globallivestock_rabbit_dev
RABBITMQ_PASS=GlobalRabbit@Dev2025!
RMQ_AMQP_PORT=5673
RMQ_MGMT_PORT=15673

# =====================================================
# REDIS - GlobalLivestock'a ÖZEL
# =====================================================
# Maden'den bağımsız, kendi Redis'i
REDIS_PORT=6380

# =====================================================
# MINIO - GlobalLivestock'a ÖZEL
# =====================================================
# Maden'den bağımsız, kendi MinIO'su
MINIO_ROOT_USER=globallivestock_minio_admin
MINIO_ROOT_PASSWORD=GlobalMinIO@2025!Dev
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
MINIO_BUCKET_NAME=globallivestock-dev

# =====================================================
# DOCKER REGISTRY
# =====================================================
REG=mstfaock
TAG=dev

# =====================================================
# API PORTS - GlobalLivestock
# =====================================================
GLOBALLIVESTOCK_API_PORT=5100
IAM_API_PORT=5101

# =====================================================
# FILE STORAGE
# =====================================================
GLOBALLIVESTOCK_FILE_STORAGE_PATH=/app/storage/globallivestock-dev

# =====================================================
# EMAIL SETTINGS (Brevo - Development)
# =====================================================
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=YOUR_BREVO_USERNAME
BREVO_SMTP_PASS=YOUR_BREVO_PASSWORD
BREVO_FROM_EMAIL=noreply-dev@livestock-trading.com
BREVO_FROM_NAME=Livestock Trading Dev

# =====================================================
# SMS SETTINGS (Development)
# =====================================================
NETGSM_USERNAME=YOUR_NETGSM_USERNAME
NETGSM_PASSWORD=YOUR_NETGSM_PASSWORD