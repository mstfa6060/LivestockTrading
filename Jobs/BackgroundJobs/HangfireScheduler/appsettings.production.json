{
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "Hangfire": "Information"
        }
    },
    "ConnectionStrings": {
        "Hangfire": "Server=YOUR_PROD_SERVER_IP,1433;Database=GlobalLivestock_Prod;User Id=globallivestock_prod_user;Password=YOUR_PROD_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;"
    },
    "ApplicationSettings": {
        "Urls": {
            "LivestockTradingApi": "http://livestocktrading-api:8080"
        }
    },
    "HangfireSettings": {
        "User": {
            "Username": "${HANGFIRE_USERNAME}",
            "Password": "${HANGFIRE_PASSWORD}"
        },
        "SystemSecret": "${HANGFIRE_SYSTEM_SECRET}"
    },
    "SystemSettings": {
        "HangfireSystemSecret": "${HANGFIRE_SYSTEM_SECRET}"
    }
}
