{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Hangfire": "Server=YOUR_SERVER_IP,1433;Database=GlobalLivestock;User Id=globallivestock_user;Password=YOUR_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "ApplicationSettings": {
    "Urls": {
      "LivestockTradingApi": "http://localhost:5001"
    }
  },
  "HangfireSettings": {
    "User": {
      "Username": "admin",
      "Password": "YOUR_HANGFIRE_ADMIN_PASSWORD"
    },
    "SystemSecret": "YOUR_HANGFIRE_SYSTEM_SECRET"
  },
  "SystemSettings": {
    "HangfireSystemSecret": "YOUR_HANGFIRE_SYSTEM_SECRET"
  }
}
