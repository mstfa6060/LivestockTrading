{
  "runtime": "Net100",
  "documentGenerator": {
    "aspNetCoreToOpenApi": {
      "project": "src/Bootstrapper/Livestock.Host/Livestock.Host.csproj",
      "noBuild": true,
      "documentName": "v1",
      "output": "generated/openapi.json"
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "className": "{controller}Client",
      "template": "Axios",
      "generateClientClasses": true,
      "generateClientInterfaces": true,
      "generateOptionalParameters": true,
      "exportTypes": true,
      "typeStyle": "Interface",
      "operationGenerationMode": "MultipleClientsFromFirstTagAndOperationName",
      "output": "generated/api-client.ts"
    }
  }
}
