<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <OutputType>Library</OutputType>
    <!-- Prevent generating Program.cs requirements -->
    <NoDefaultLaunchSettingsFile>true</NoDefaultLaunchSettingsFile>
    <!-- Force all assemblies to be copied to publish folder for arfblocks-cli reflection -->
    <PublishWithAspNetCoreTargetManifest>false</PublishWithAspNetCoreTargetManifest>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\GlobalLivestock.Domain\GlobalLivestock.Domain.csproj" />
    <ProjectReference Include="..\GlobalLivestock.Infrastructure\GlobalLivestock.Infrastructure.csproj" />
    <ProjectReference Include="..\..\..\Common\Services\Common.Services.Messaging\Common.Services.Messaging.csproj" />
    <ProjectReference Include="..\..\..\Common\Contracts\Common.Contracts.Event\Common.Contracts.Event.csproj" />
    <ProjectReference Include="..\..\..\Common\Common.Contracts.PubSub\Common.Contracts.PubSub.csproj" />
    <ProjectReference Include="..\..\..\Common\Definitions\Common.Definitions.Domain\Common.Definitions.Domain.csproj" />
    <ProjectReference Include="..\..\..\Common\Contracts\Common.Contracts.Queue\Common.Contracts.Queue.csproj" />
    <ProjectReference Include="..\..\..\Common\Helpers\Common.Helpers.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Arfware.ArfBlocks.Test" Version="2.0.0" />
    <PackageReference Include="Arfware.ArfFipaso" Version="1.1.1" />
    <PackageReference Include="FluentValidation" Version="10.1.0" />
    <PackageReference Include="FluentAssertions" Version="6.11.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="5.6.3" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.0" />
  </ItemGroup>

</Project>
