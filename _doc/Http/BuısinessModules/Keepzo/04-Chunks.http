
# Direct API
@Url = http://localhost:5000

# Gateway
# @Url = http://localhost:8080/keepzo/api/keepzo

@LicenseKey = YOUR_LICENSE_KEY_HERE
@JobId = 00000000-0000-0000-0000-000000000000

###############################################
# CHUNKS - Commands
###############################################

### Upload Chunk (Multipart/Form-Data)
# Dosya chunk'i yukler
POST {{Url}}/Chunks/Upload
Accept: application/json
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="licenseKey"

{{LicenseKey}}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="jobId"

{{JobId}}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="relativePath"

Documents/Projects/report.pdf
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="fileHash"

e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="fileSizeBytes"

10485760
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="fileModifiedAt"

2024-01-15T10:00:00Z
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="chunkIndex"

0
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="totalChunks"

2
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="chunkHash"

a1b2c3d4e5f6789012345678901234567890123456789012345678901234abcd
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="chunkData"; filename="chunk_0.bin"
Content-Type: application/octet-stream

< ./test-chunk.bin
------WebKitFormBoundary7MA4YWxkTrZu0gW--


### Upload Second Chunk
# Ikinci chunk'i yukler
POST {{Url}}/Chunks/Upload
Accept: application/json
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="licenseKey"

{{LicenseKey}}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="jobId"

{{JobId}}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="relativePath"

Documents/Projects/report.pdf
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="fileHash"

e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="fileSizeBytes"

10485760
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="fileModifiedAt"

2024-01-15T10:00:00Z
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="chunkIndex"

1
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="totalChunks"

2
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="chunkHash"

b2c3d4e5f6789012345678901234567890123456789012345678901234abcde
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="chunkData"; filename="chunk_1.bin"
