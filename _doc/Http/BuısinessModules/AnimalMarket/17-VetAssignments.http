###############################################################################
#                      VET ASSIGNMENTS (Veteriner Atamaları)                   #
#                                                                              #
#  Hayvanlara veteriner atama işlemleri                                       #
#  Muayene öncesi atama ve ziyaret takibi                                     #
###############################################################################

@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..j26ak-YthzneEIegcgjCADs_w-TZ6AMP5W0lahWfW28

### ═══════════════════════════════════════════════════════════════════════════
###                              COMMANDS
### ═══════════════════════════════════════════════════════════════════════════

### Veteriner Ataması Oluştur
# Hayvana veteriner atar.
# status: 0=Bekliyor, 1=Ziyaret Edildi, 2=İptal
POST {{baseUrl}}/VetAssignments/Create
Content-Type: application/json
Authorization: {{token}}

{
    "animalId": "00000000-0000-0000-0000-000000000000",
    "vetUserId": "00000000-0000-0000-0000-000000000000",
    "assignedAt": "2025-11-29T10:00:00",
    "visitedAt": null,
    "status": 0,
    "notes": "Satış öncesi sağlık kontrolü gerekli"
}

###

### Veteriner Ataması Güncelle
# Mevcut veteriner atamasını günceller.
# Ziyaret sonrası durum güncellenir.
POST {{baseUrl}}/VetAssignments/Update
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "animalId": "00000000-0000-0000-0000-000000000000",
    "vetUserId": "00000000-0000-0000-0000-000000000000",
    "assignedAt": "2025-11-29T10:00:00",
    "visitedAt": "2025-11-29T14:00:00",
    "status": 1,
    "notes": "Muayene tamamlandı, hayvan sağlıklı"
}

###

### Veteriner Ataması Sil
# Veteriner atamasını siler.
POST {{baseUrl}}/VetAssignments/Delete
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "isDeleted": true
}

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Tüm Veteriner Atamalarını Listele
# Tüm veteriner atamalarını listeler.
POST {{baseUrl}}/VetAssignments/All
Content-Type: application/json
Authorization: {{token}}

{
    "sorting": {
        "field": "assignedAt",
        "order": "desc"
    },
    "filters": {},
    "pageRequest": {
        "page": 1,
        "pageSize": 20
    }
}

###

### Veteriner Ataması Detayı
# Belirli bir veteriner atamasının detayını getirir.
POST {{baseUrl}}/VetAssignments/Detail
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000"
}

###

### Veteriner Ataması Seç (Pick)
# Dropdown için veteriner ataması listesi.
POST {{baseUrl}}/VetAssignments/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "selectedIds": [],
    "keyword": "",
    "limit": 10
}
