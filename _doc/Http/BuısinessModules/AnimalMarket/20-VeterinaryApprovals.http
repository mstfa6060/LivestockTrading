###############################################################################
#                   VETERINARY APPROVALS (Veteriner Onayları)                  #
#                                                                              #
#  Hayvan satışı için veteriner sağlık onayı süreci                           #
#  Onay alınmadan teslimat başlatılamaz                                       #
###############################################################################

@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..w-2XDW87ge38nVFYCU5USL9A63FH1bjRi9MOsMC4yTc

### ═══════════════════════════════════════════════════════════════════════════
###                              COMMANDS
### ═══════════════════════════════════════════════════════════════════════════

### Veteriner Onayı Oluştur
# Hayvan için veteriner onay kaydı oluşturur.
# status: 0=Bekliyor, 1=Onaylandı, 2=Reddedildi
# approvalType: 0=Satış Öncesi, 1=Nakil Öncesi
POST {{baseUrl}}/VeterinaryApprovals/Create
Content-Type: application/json
Authorization: {{token}}

{
    "animalId": "00000000-0000-0000-0000-000000000000",
    "veterinarianId": "00000000-0000-0000-0000-000000000000",
    "status": 0,
    "approvalType": 0,
    "notes": "Muayene için bekleniyor",
    "approvedAt": null,
    "rejectedAt": null,
    "healthScore": null,
    "nextCheckDate": null,
    "documentBucketId": null
}

###

### Veteriner Onayı Güncelle
# Mevcut veteriner onayını günceller.
POST {{baseUrl}}/VeterinaryApprovals/Update
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "status": 1,
    "approvalType": 0,
    "notes": "Hayvan sağlıklı, satışa uygun",
    "healthScore": 95,
    "nextCheckDate": "2026-05-29",
    "documentBucketId": null,
    "approvedAt": "2025-11-29T14:00:00",
    "rejectedAt": null
}

###

### Veteriner Onayı Ver (Approve)
# Veteriner olarak hayvanı onaylar.
# Onay verilince teslimat süreci başlayabilir.
POST {{baseUrl}}/VeterinaryApprovals/Approve
Content-Type: application/json
Authorization: {{token}}

{
    "approvalId": "00000000-0000-0000-0000-000000000000",
    "veterinarianId": "00000000-0000-0000-0000-000000000000",
    "notes": "Hayvan sağlıklı, nakil için uygundur",
    "healthScore": 92
}

###

### Veteriner Onayı Sil
# Veteriner onayını siler.
POST {{baseUrl}}/VeterinaryApprovals/Delete
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "isDeleted": true
}

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Tüm Veteriner Onaylarını Listele
# Tüm veteriner onaylarını listeler.
POST {{baseUrl}}/VeterinaryApprovals/All
Content-Type: application/json
Authorization: {{token}}

{
  "sorting": {
    "key": "createdAt",
    "direction": 1
  },
  "filters": [
    {
      "key": "veterinarianId",
      "type": "guid",
      "isUsed": true,
      "values": [
        "9fc77489-055b-460f-8594-44d52272efa4"
      ],
      "min": {},
      "max": {},
      "conditionType": "Equals"
    }
  ],
  "pageRequest": {
    "currentPage": 1,
    "perPageCount": 50,
    "listAll": false
  }
}
###

### Veteriner Onayı Detayı
# Belirli bir veteriner onayının detayını getirir.
POST {{baseUrl}}/VeterinaryApprovals/Detail
Content-Type: application/json
Authorization: {{token}}

{
    "veterinaryApprovalId": "00000000-0000-0000-0000-000000000000",
    "languageCode": "tr"
}

###

### Veteriner Onayı Seç (Pick)
# Dropdown için veteriner onayı listesi.
POST {{baseUrl}}/VeterinaryApprovals/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "selectedIds": [],
    "keyword": "",
    "limit": 10
}
