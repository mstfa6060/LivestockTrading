###############################################################################
#                   VETERINARIAN PROFILES (Veteriner Profilleri)               #
#                                                                              #
#  Veteriner hekim profillerinin yönetimi                                     #
#  Lisans, uzmanlık, ücret ve hizmet bölgesi bilgileri                        #
###############################################################################

@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..kBq8z4dwphRffZ8ZB8oN5VToeQl3PRRylVIwsqOvlWU

### ═══════════════════════════════════════════════════════════════════════════
###                              COMMANDS
### ═══════════════════════════════════════════════════════════════════════════

### Veteriner Profili Oluştur
# Kullanıcıya veteriner profili ekler.
# Lisans numarası, uzmanlık alanı ve ücret bilgileri zorunludur.
POST {{baseUrl}}/VeterinarianProfiles/Create
Content-Type: application/json
Authorization: {{token}}

{
    "companyId": "00000000-0000-0000-0000-000000000000",
    "userId": "00000000-0000-0000-0000-000000000000",
    "licenseNumber": "VET-42-001",
    "specialization": "Büyükbaş Hayvan Hastalıkları",
    "yearsOfExperience": 8,
    "educationalBackground": "Selçuk Üniversitesi Veterinerlik Fakültesi",
    "certificationIds": [],
    "serviceAreaIds": [],
    "consultationFee": 500.00,
    "visitFee": 1000.00,
    "isEmergencyAvailable": true,
    "isActive": true
}

###

### Veteriner Profili Güncelle
# Mevcut veteriner profilini günceller.
POST {{baseUrl}}/VeterinarianProfiles/Update
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "companyId": "00000000-0000-0000-0000-000000000000",
    "userId": "00000000-0000-0000-0000-000000000000",
    "licenseNumber": "VET-42-001",
    "specialization": "Büyükbaş ve Küçükbaş Hastalıkları",
    "yearsOfExperience": 10,
    "educationalBackground": "Selçuk Üniversitesi Veterinerlik Fakültesi, Yüksek Lisans",
    "certificationIds": [],
    "serviceAreaIds": [],
    "consultationFee": 600.00,
    "visitFee": 1200.00,
    "isEmergencyAvailable": true,
    "isActive": true
}

###

### Veteriner Profili Sil
# Veteriner profilini soft-delete ile siler.
POST {{baseUrl}}/VeterinarianProfiles/Delete
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "isDeleted": true
}

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Tüm Veteriner Profillerini Listele
# Filtreleme ve sayfalama ile tüm veteriner profillerini listeler.
POST {{baseUrl}}/VeterinarianProfiles/All
Content-Type: application/json
Authorization: {{token}}

{
    "sorting": {
        "field": "createdAt",
        "order": "desc"
    },
    "filters": {},
    "pageRequest": {
        "page": 1,
        "pageSize": 20
    }
}

###

### Veteriner Profil Detayı
# Belirli bir veteriner profilinin detaylı bilgilerini getirir.
POST {{baseUrl}}/VeterinarianProfiles/Detail
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000"
}

###

### Çiftlik İçin Müsait Veterinerler
# Belirli bir çiftliğin konumuna göre müsait veterinerleri listeler.
# Çiftlik sahibi veteriner ararken bu endpoint'i kullanır.
POST {{baseUrl}}/VeterinarianProfiles/GetAvailableForFarm
Content-Type: application/json
Authorization: {{token}}

{
    "farmId": "00000000-0000-0000-0000-000000000000",
    "sorting": {
        "field": "rating",
        "order": "desc"
    },
    "filters": {},
    "pageRequest": {
        "page": 1,
        "pageSize": 20
    }
}

###

### Veteriner Profili Seç (Pick)
# Dropdown/autocomplete için veteriner profili listesi.
POST {{baseUrl}}/VeterinarianProfiles/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "selectedIds": [],
    "keyword": "",
    "limit": 10
}
