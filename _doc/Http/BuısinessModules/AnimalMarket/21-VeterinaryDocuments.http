@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..kBq8z4dwphRffZ8ZB8oN5VToeQl3PRRylVIwsqOvlWU

### ═══════════════════════════════════════════════════════════════════════════
###                              COMMANDS
### ═══════════════════════════════════════════════════════════════════════════

### Veteriner Belgesi Oluştur
# Hayvan için veteriner belgesi ekler.
# documentType: 0=Sağlık Raporu, 1=Aşı Kartı, 2=Nakil Belgesi, 3=Diğer
POST {{baseUrl}}/VeterinaryDocuments/Create
Content-Type: application/json
Authorization: {{token}}

{
    "animalId": "00000000-0000-0000-0000-000000000000",
    "documentType": 0,
    "issueDate": "2025-11-29",
    "documentBucketId": "bucket-id",
    "fileName": "saglik-raporu.pdf",
    "fileSize": 102400,
    "fileType": "application/pdf",
    "documentNumber": "DOC-2025-001",
    "title": "Sağlık Raporu",
    "description": "Yıllık sağlık kontrolü raporu",
    "veterinarianName": "Dr. Ahmet Yılmaz",
    "veterinarianLicense": "VET-42-001",
    "issuingClinic": "Merkez Veteriner Kliniği",
    "clinicAddress": "Konya Merkez",
    "expiryDate": "2026-11-29",
    "nextCheckupDate": "2026-05-29",
    "companyId": "00000000-0000-0000-0000-000000000000"
}

###

### Veteriner Belgesi Güncelle
# Mevcut veteriner belgesini günceller.
POST {{baseUrl}}/VeterinaryDocuments/Update
Content-Type: application/json
Authorization: {{token}}

{
    "veterinaryDocumentId": "00000000-0000-0000-0000-000000000000",
    "companyId": "00000000-0000-0000-0000-000000000000",
    "animalId": "00000000-0000-0000-0000-000000000000",
    "documentType": 0,
    "documentNumber": "DOC-2025-001-REV",
    "title": "Sağlık Raporu - Revize",
    "description": "Güncellenmiş sağlık raporu",
    "veterinarianName": "Dr. Ahmet Yılmaz",
    "veterinarianLicense": "VET-42-001",
    "issuingClinic": "Merkez Veteriner Kliniği",
    "clinicAddress": "Konya Merkez",
    "issueDate": "2025-11-29",
    "expiryDate": "2026-11-29",
    "nextCheckupDate": "2026-05-29",
    "documentBucketId": "bucket-id",
    "fileName": "saglik-raporu-v2.pdf",
    "fileSize": 115200,
    "fileType": "application/pdf",
    "isVerified": true,
    "verifiedByUserId": "00000000-0000-0000-0000-000000000000",
    "verificationDate": "2025-11-29"
}

###

### Veteriner Belgesi Sil
# Veteriner belgesini siler.
POST {{baseUrl}}/VeterinaryDocuments/Delete
Content-Type: application/json
Authorization: {{token}}

{
    "veterinaryDocumentId": "00000000-0000-0000-0000-000000000000",
    "companyId": "00000000-0000-0000-0000-000000000000"
}

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Tüm Veteriner Belgelerini Listele
# Tüm veteriner belgelerini listeler.
POST {{baseUrl}}/VeterinaryDocuments/All
Content-Type: application/json
Authorization: {{token}}

{
    "sorting": {
        "field": "issueDate",
        "order": "desc"
    },
    "filters": {},
    "pageRequest": {
        "page": 1,
        "pageSize": 20
    }
}

###

### Veteriner Belgesi Detayı
# Belirli bir veteriner belgesinin detayını getirir.
POST {{baseUrl}}/VeterinaryDocuments/Detail
Content-Type: application/json
Authorization: {{token}}

{
    "documentId": "00000000-0000-0000-0000-000000000000"
}

###

### Veteriner Belgesi Seç (Pick)
# Dropdown için veteriner belgesi listesi.
POST {{baseUrl}}/VeterinaryDocuments/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "selectedIds": [],
    "keyword": "",
    "limit": 10
}
