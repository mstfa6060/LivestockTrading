###############################################################################
#                    DELIVERY REQUESTS (Teslimat Talepleri)                    #
#                                                                              #
#  Nakliyecilerin teslimat siparişlerine ilgi beyanı/talep oluşturması        #
#  Akış: Nakliyeci talep oluşturur -> Admin görür -> Admin nakliyeci atar     #
###############################################################################

@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..kBq8z4dwphRffZ8ZB8oN5VToeQl3PRRylVIwsqOvlWU

### ═══════════════════════════════════════════════════════════════════════════
###                              COMMANDS
### ═══════════════════════════════════════════════════════════════════════════

### Teslimat Talebi Oluştur (Nakliyeci)
# Nakliyeci olarak bir teslimat siparişine ilgi beyanı/talep oluşturur.
# proposedPrice: Nakliyecinin teklif ettiği ücret
# estimatedHours: Tahmini teslimat süresi (saat)
POST {{baseUrl}}/DeliveryRequests/Create
Content-Type: application/json
Authorization: {{token}}

{
    "deliveryOrderId": "00000000-0000-0000-0000-000000000000",
    "notes": "Bu teslimatla ilgileniyorum. Soğutmalı aracım mevcut.",
    "proposedPrice": 2500.00,
    "estimatedHours": 8
}

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Teslimat Siparişine Gelen Talepleri Getir
# Belirli bir teslimat siparişine gelen tüm nakliyeci taleplerini listeler.
# Admin ve sipariş sahibi bu listeyi görebilir.
POST {{baseUrl}}/DeliveryRequests/GetByDeliveryOrder
Content-Type: application/json
Authorization: {{token}}

{
    "deliveryOrderId": "00000000-0000-0000-0000-000000000000"
}
