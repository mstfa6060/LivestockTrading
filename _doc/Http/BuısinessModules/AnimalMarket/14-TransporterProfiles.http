@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..wL-ewPV1qS1zDIlKzB-hSiWJ244h4dahODV4r51ldak

### ═══════════════════════════════════════════════════════════════════════════
###                              COMMANDS
### ═══════════════════════════════════════════════════════════════════════════

### Nakliyeci Profili Oluştur
# Kullanıcıya nakliyeci profili ekler.
# vehicleCapacities: Her hayvan tipi için taşıma kapasitesi
POST {{baseUrl}}/TransporterProfiles/Create
Content-Type: application/json
Authorization: {{token}}

{
    "userId": "00000000-0000-0000-0000-000000000000",
    "companyId": "00000000-0000-0000-0000-000000000000",
    "vehicleType": "Kamyon",
    "vehiclePlate": "34 ABC 123",
    "isLiveTransportCertified": true,
    "isActive": true,
    "city": "İstanbul",
    "district": "Kartal",
    "address": "Cevizli Mah. No:10",
    "addressLatitude": 40.9167,
    "addressLongitude": 29.1833,
    "vehicleCapacities": [
        {
            "animalType": 0,
            "capacity": 10
        },
        {
            "animalType": 1,
            "capacity": 50
        }
    ]
}

###

### Nakliyeci Profili Güncelle
# Mevcut nakliyeci profilini günceller.
POST {{baseUrl}}/TransporterProfiles/Update
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "userId": "00000000-0000-0000-0000-000000000000",
    "companyId": "00000000-0000-0000-0000-000000000000",
    "vehicleType": "TIR",
    "vehiclePlate": "34 XYZ 789",
    "vehicleCapacity": 20,
    "isLiveTransportCertified": true,
    "isActive": true,
    "city": "İstanbul",
    "district": "Maltepe",
    "address": "Yeni Adres",
    "addressLatitude": 40.9200,
    "addressLongitude": 29.2000,
    "vehicleCapacities": [
        {
            "animalType": 0,
            "capacity": 15
        }
    ]
}

###

### Nakliyeci Profili Sil
# Nakliyeci profilini siler.
POST {{baseUrl}}/TransporterProfiles/Delete
Content-Type: application/json
Authorization: {{token}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "isDeleted": true
}

###

### Nakliyeci Müsaitlik Güncelle
# Nakliyecinin müsaitlik durumunu ve anlık konumunu günceller.
# Mobil uygulama tarafından periyodik çağrılır.
POST {{baseUrl}}/TransporterProfiles/UpdateAvailability
Content-Type: application/json
Authorization: {{token}}

{
    "transporterId": "00000000-0000-0000-0000-000000000000",
    "isAvailable": true,
    "latitude": 40.9167,
    "longitude": 29.1833
}

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Tüm Nakliyeci Profillerini Listele
# Tüm nakliyeci profillerini listeler.
POST {{baseUrl}}/TransporterProfiles/All
Content-Type: application/json
Authorization: {{token}}

{
    "sorting": {
        "field": "createdAt",
        "order": "desc"
    },
    "filters": {},
    "pageRequest": {
        "page": 1,
        "pageSize": 20
    }
}

###

### Nakliyeci Profil Detayı
# Belirli bir nakliyeci profilinin detayını getirir.
POST {{baseUrl}}/TransporterProfiles/Detail
Content-Type: application/json
Authorization: {{token}}

{
    "id": "3d5a8d0f-ba79-4a1d-9735-078573ceacdf"
}

###

### Haritada Nakliyecileri Getir
# Belirli koordinatlar içindeki müsait nakliyecileri getirir.
# Harita görünümünde nakliyeci konumlarını göstermek için kullanılır.
POST {{baseUrl}}/TransporterProfiles/GetOnMap
Content-Type: application/json
Authorization: {{token}}

{
    "bounds": {
        "northEast": {
            "latitude": 41.5,
            "longitude": 30.0
        },
        "southWest": {
            "latitude": 40.5,
            "longitude": 28.5
        }
    },
    "filters": {}
}

###

### Nakliyeci Profili Seç (Pick)
# Dropdown için nakliyeci profili listesi.
POST {{baseUrl}}/TransporterProfiles/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "selectedIds": [],
    "keyword": "",
    "limit": 10
}
