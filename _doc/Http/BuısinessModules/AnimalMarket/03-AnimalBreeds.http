###############################################################################
#                        ANIMAL BREEDS (Hayvan Irkları)                        #
#                                                                              #
#  Hayvan ırklarının listelenmesi                                             #
#  Hayvan tipine göre filtreleme yapılabilir                                  #
###############################################################################

@baseUrl = http://localhost:22321
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..kBq8z4dwphRffZ8ZB8oN5VToeQl3PRRylVIwsqOvlWU

### ═══════════════════════════════════════════════════════════════════════════
###                              QUERIES
### ═══════════════════════════════════════════════════════════════════════════

### Tüm Irkları Listele
# Hayvan ırklarını listeler.
POST {{baseUrl}}/AnimalBreeds/All
Content-Type: application/json
Authorization: {{token}}

{
    "sorting": {
        "field": "name",
        "order": "asc"
    },
    "filters": {},
    "pageRequest": {
        "page": 1,
        "pageSize": 50
    }
}

###

### Irk Seç (Pick)
# Hayvan tipine göre ırk listesi (dropdown için).
# type: 0=Büyükbaş, 1=Küçükbaş, 2=Kanatlı, 3=At, 4=Diğer
POST {{baseUrl}}/AnimalBreeds/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "type": 0,
    "selectedIds": [],
    "keyword": "holstein",
    "limit": 10
}

###

### Küçükbaş Irkları
# Küçükbaş hayvan ırklarını listeler.
POST {{baseUrl}}/AnimalBreeds/Pick
Content-Type: application/json
Authorization: {{token}}

{
    "type": 1,
    "selectedIds": [],
    "keyword": "",
    "limit": 20
}
