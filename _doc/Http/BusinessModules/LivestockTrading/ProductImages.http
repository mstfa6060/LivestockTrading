@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/ProductImages/Create
Content-Type: application/json

{
    "productId": "00000000-0000-0000-0000-000000000001",
    "imageUrl": "https://example.com/products/holstein-cow-01.jpg",
    "thumbnailUrl": "https://example.com/products/thumbnails/holstein-cow-01.jpg",
    "altText": "Holstein dairy cow front view",
    "sortOrder": 1,
    "isPrimary": true
}

