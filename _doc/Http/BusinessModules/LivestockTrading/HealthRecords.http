    "medications": "[{\"name\": \"Ivermectin\", \"dosage\": \"10ml\", \"frequency\": \"Single dose\"}]",
    "notes": "Animal in excellent condition, recommend follow-up in 6 months",
    "followUpDate": "2025-07-10T10:00:00Z",
    "documentUrl": "https://example.com/documents/health-record-001.pdf"
}

