@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/Banners/Create
Content-Type: application/json

{
    "title": "Spring Sale - Premium Livestock",
    "description": "Get up to 20% off on selected livestock this spring season",
    "imageUrl": "https://example.com/banners/spring-sale-2025.jpg",
    "targetUrl": "/products?filter=spring-sale",
    "position": 0,
    "startDate": "2025-03-01T00:00:00Z",
    "endDate": "2025-05-31T23:59:59Z",
    "isActive": true,
    "displayOrder": 1
}

