@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/ProductVariants/Create
Content-Type: application/json

{
    "productId": "00000000-0000-0000-0000-000000000001",
    "name": "2-Year-Old Female",
    "sku": "HOL-F-2Y-001",
    "price": 15000.00,
    "discountedPrice": 14500.00,
    "stockQuantity": 3,
    "isInStock": true,
    "attributes": "{\"age\": \"2 years\", \"gender\": \"Female\", \"weight\": \"450kg\"}",
    "imageUrl": "https://example.com/products/variant-1.jpg",
    "isActive": true,
    "sortOrder": 1
}

