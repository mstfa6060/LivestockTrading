@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/Farms/Create
Content-Type: application/json

{
    "name": "Sunset Valley Farm",
    "description": "A large-scale organic dairy and cattle farm",
    "registrationNumber": "FARM-2024-0001",
    "sellerId": "00000000-0000-0000-0000-000000000001",
    "locationId": "00000000-0000-0000-0000-000000000002",
    "type": 0,
    "totalAreaHectares": 250.5,
    "cultivatedAreaHectares": 180.0,
    "certifications": "[\"ISO 22000\", \"Organic Certified\", \"GlobalGAP\"]",
    "isOrganic": true,
    "imageUrls": "[\"https://example.com/farms/sunset-1.jpg\", \"https://example.com/farms/sunset-2.jpg\"]",
    "videoUrl": "https://example.com/videos/sunset-farm-tour.mp4",
    "isActive": true
}

