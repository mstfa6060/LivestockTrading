@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/ShippingCarriers/Create
Content-Type: application/json

{
    "name": "National Livestock Carriers",
    "code": "NLC",
    "website": "https://www.nlcarriers.com",
    "trackingUrlTemplate": "https://www.nlcarriers.com/track/{trackingNumber}",
    "isActive": true,
    "supportedCountries": "[\"TR\", \"DE\", \"FR\", \"NL\", \"BE\", \"AT\"]"
}

### All
POST {{BaseUrl}}/ShippingCarriers/All
Content-Type: application/json

{
    "sorting": null,
    "filters": [],
    "pageRequest": { "page": 1, "pageSize": 10 }
}

