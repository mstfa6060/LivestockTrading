@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/AppVersions/Create
Content-Type: application/json

{
    "platform": 1,
    "minSupportedVersion": "1.0.0",
    "latestVersion": "1.2.0",
    "storeUrl": "https://play.google.com/store/apps/details?id=com.livestocktrading.app",
    "updateMessage": "Yeni surumumuz yayinda!",
    "isActive": true
}

### All
POST {{BaseUrl}}/AppVersions/All
Content-Type: application/json

{
    "platform": null,
    "sorting": null,
    "filters": [],
    "pageRequest": { "page": 1, "pageSize": 10 }
}

