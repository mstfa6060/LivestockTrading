@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/Vaccinations/Create
Content-Type: application/json

{
    "animalInfoId": "00000000-0000-0000-0000-000000000001",
    "vaccineName": "Foot and Mouth Disease Vaccine",
    "vaccineType": "Inactivated",
    "batchNumber": "BATCH-FMD-2025-001",
    "vaccinationDate": "2025-01-15T09:00:00Z",
    "nextDueDate": "2025-07-15T09:00:00Z",
    "veterinarianName": "Dr. Ayse Kara",
    "veterinarianLicense": "VET-TR-67890",
    "notes": "No adverse reactions observed, animal in good health",
    "certificateUrl": "https://example.com/certificates/vaccination-fmd-001.pdf"
}

