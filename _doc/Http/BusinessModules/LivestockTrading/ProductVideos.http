@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/ProductVideos/Create
Content-Type: application/json

{
    "productId": "00000000-0000-0000-0000-000000000001",
    "videoUrl": "https://example.com/videos/holstein-cow-walkthrough.mp4",
    "thumbnailUrl": "https://example.com/videos/thumbnails/holstein-cow-walkthrough.jpg",
    "title": "Holstein Cow - Farm Walkthrough",
    "durationSeconds": 120,
    "sortOrder": 1,
    "provider": 0
}

