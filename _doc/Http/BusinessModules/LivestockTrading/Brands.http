@BaseUrl = http://localhost:5221

### Create
POST {{BaseUrl}}/Brands/Create
Content-Type: application/json

{
    "name": "Test Brand",
    "slug": "test-brand",
    "description": "A test brand for livestock products",
    "logoUrl": "https://example.com/logos/test-brand.png",
    "website": "https://www.testbrand.com",
    "email": "info@testbrand.com",
    "phone": "+905551234567",
    "countryCode": "TR",
    "isActive": true
}

