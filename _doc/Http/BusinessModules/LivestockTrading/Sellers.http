### Pick
POST {{BaseUrl}}/Sellers/Pick
Content-Type: application/json

{
    "selectedIds": [],
    "keyword": "",
    "limit": 10
}

### Update
POST {{BaseUrl}}/Sellers/Update
Content-Type: application/json

{
    "id": "00000000-0000-0000-0000-000000000000",
    "userId": "00000000-0000-0000-0000-000000000001",
    "businessName": "Green Valley Livestock - Updated",
    "businessType": "Farm & Ranch",
    "taxNumber": "1234567890",
    "registrationNumber": "REG-2024-001",
    "description": "Updated description - Premium livestock supplier",
    "logoUrl": "https://example.com/logos/green-valley-new.png",
    "bannerUrl": "https://example.com/banners/green-valley-new.jpg",
    "email": "sales@greenvalley.com",
    "phone": "+905559876543",
    "website": "https://www.greenvalley.com",
    "isActive": true,
    "status": 0,
    "businessHours": "{\"monday\": \"09:00-17:00\", \"tuesday\": \"09:00-17:00\"}",
    "acceptedPaymentMethods": "[\"bank_transfer\", \"credit_card\"]",
    "returnPolicy": "Updated return policy",
    "shippingPolicy": "Updated shipping policy",
    "socialMediaLinks": "{\"instagram\": \"@greenvalleyfarm\"}"
}

### Delete
POST {{BaseUrl}}/Sellers/Delete
Content-Type: application/json

{
    "id": "00000000-0000-0000-0000-000000000000"
}

### Verify (Admin/Moderator only)
POST {{BaseUrl}}/Sellers/Verify
Content-Type: application/json
Authorization: Bearer {{AdminToken}}

{
    "id": "00000000-0000-0000-0000-000000000000"
}

### Suspend (Admin/Moderator only)
POST {{BaseUrl}}/Sellers/Suspend
Content-Type: application/json
Authorization: Bearer {{AdminToken}}

{
    "id": "00000000-0000-0000-0000-000000000000",
    "reason": "Violation of platform terms of service"
}
